void initSIM7600() {
  Serial.println("[SIM] Đang khởi động module...");
  delay(5000);
  
  sendSIMCommand("AT", "OK", SIM_CMD_TIMEOUT);
  sendSIMCommand("AT+CPIN?", "READY", SIM_CMD_TIMEOUT);
