        Serial.println("[HTTP] Response: " + response);
      }
    } else {
      Serial.printf("[HTTP] ✗ Error: %s\n", http.errorToString(httpCode).c_str());
    }
    
    http.end();
  } else {
    Serial.println("[HTTP] ✗ Connection failed");
  }
}

// =====================================================================
// GỬI HTTP QUA SIM7600 - IMPROVED WITH RESPONSE CHECK
// =====================================================================

bool sendHTTPViaSIM(String jsonData) {
  Serial.println("[SIM-HTTP] Starting HTTP transaction...");
  
  // Init HTTP
  if (!sendSIMCommand("AT+HTTPINIT", "OK", SIM_CMD_TIMEOUT)) {
    Serial.println("[SIM-HTTP] Failed to init");
    sendSIMCommand("AT+HTTPTERM", NULL, 1000); // Cleanup
    return false;
  }
  
  // Set URL
  String urlCmd = "AT+HTTPPARA=\"URL\",\"" + String(SIM_SERVER_URL) + "\"";
  if (!sendSIMCommand(urlCmd.c_str(), "OK", SIM_CMD_TIMEOUT)) {
    Serial.println("[SIM-HTTP] Failed to set URL");
    sendSIMCommand("AT+HTTPTERM", NULL, 1000);
    return false;
  }
  
  // Set Content-Type
  if (!sendSIMCommand("AT+HTTPPARA=\"CONTENT\",\"application/json\"", "OK", SIM_CMD_TIMEOUT)) {
    Serial.println("[SIM-HTTP] Failed to set content type");
    sendSIMCommand("AT+HTTPTERM", NULL, 1000);
    return false;
  }
  
  // Set Authorization header
  String authCmd = "AT+HTTPPARA=\"USERDATA\",\"Authorization: Bearer " + String(DEVICE_TOKEN) + "\"";
  if (!sendSIMCommand(authCmd.c_str(), "OK", SIM_CMD_TIMEOUT)) {
    Serial.println("[SIM-HTTP] Failed to set auth header");
    sendSIMCommand("AT+HTTPTERM", NULL, 1000);
    return false;
  }
  
  // Set data
  String dataCmd = "AT+HTTPDATA=" + String(jsonData.length()) + ",10000";
  simSerial.println(dataCmd);
  
  if (!waitForSIMResponse("DOWNLOAD", 2000)) {
    Serial.println("[SIM-HTTP] Failed to enter data mode");
    sendSIMCommand("AT+HTTPTERM", NULL, 1000);
    return false;
  }
  
  simSerial.println(jsonData);
  
  if (!waitForSIMResponse("OK", 12000)) {
    Serial.println("[SIM-HTTP] Failed to upload data");
    sendSIMCommand("AT+HTTPTERM", NULL, 1000);
    return false;
  }
  
  // Perform POST request
  if (!sendSIMCommand("AT+HTTPACTION=1", "OK", SIM_CMD_TIMEOUT)) {
    Serial.println("[SIM-HTTP] Failed to execute POST");
    sendSIMCommand("AT+HTTPTERM", NULL, 1000);
    return false;
  }
  
  // Wait for +HTTPACTION response
  if (!waitForSIMResponse("+HTTPACTION", SIM_HTTP_TIMEOUT)) {
    Serial.println("[SIM-HTTP] Timeout waiting for response");
    sendSIMCommand("AT+HTTPTERM", NULL, 1000);
    return false;
  }
  
  // Read response (optional)
  sendSIMCommand("AT+HTTPREAD", NULL, 2000);
  
  // Terminate HTTP
  sendSIMCommand("AT+HTTPTERM", "OK", SIM_CMD_TIMEOUT);
  
  Serial.println("[SIM-HTTP] ✓ Transaction complete");
  return true;
}

