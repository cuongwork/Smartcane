void handleButtons() {
  // XỬ LÝ NÚT SOS - TOGGLE MODE
  if (sosTriggered) {
    sosTriggered = false;
    
    // Toggle trạng thái SOS
    sosActive = !sosActive;
    
    if (sosActive) {
      // BẬT SOS
      Serial.println("\n╔════════════════════════════════════╗");
      Serial.println("║      🚨 SOS ĐƯỢC KÍCH HOẠT 🚨      ║");
      Serial.println("║   (Bấm lại để TẮT báo động)       ║");
      Serial.println("╚════════════════════════════════════╝");
      
      currentPattern = BUZZER_SOS;
      digitalWrite(LED_STATUS, HIGH);
      sosEmergencySent = false;
      
      // Gửi cảnh báo khẩn cấp
      bool sosFlag = true;
      xQueueSend(sosQueue, &sosFlag, 0);
      
    } else {
      // TẮT SOS
      Serial.println("\n╔════════════════════════════════════╗");
      Serial.println("║      ✅ SOS ĐÃ TẮT                 ║");
      Serial.println("║   Báo động đã được hủy             ║");
      Serial.println("╚════════════════════════════════════╝");
      
      currentPattern = BUZZER_OFF;
      digitalWrite(LED_STATUS, LOW);
      sosEmergencySent = false;
    }
  }

  // XỬ LÝ NÚT TOGGLE CHỐNG QUÊN
  if (toggleTriggered) {
    toggleTriggered = false;
    
    forgetModeEnabled = !forgetModeEnabled;
    preferences.putBool("forgetMode", forgetModeEnabled);
    
    digitalWrite(LED_FORGET_MODE, forgetModeEnabled ? HIGH : LOW);
    currentPattern = forgetModeEnabled ? BUZZER_CONFIRM_ON : BUZZER_CONFIRM_OFF;
    buzzerRepeatCount = forgetModeEnabled ? 1 : 2;
    
    Serial.printf("[TOGGLE] Chế độ chống quên: %s\n", forgetModeEnabled ? "BẬT" : "TẮT");
    
    if (!forgetModeEnabled) {
      forgetAlertSent = false;
      lastTouchTime = millis();
    }
  }
}

