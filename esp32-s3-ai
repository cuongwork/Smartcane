void checkForgetMode() {
  if (!forgetModeEnabled) return;

  int fsrValue = analogRead(FORCE_SENSOR_PIN);
  unsigned long now = millis();

  if (fsrValue < FSR_THRESHOLD) {
    if (!userHolding) {
      userHolding = true;
      forgetAlertSent = false;
      digitalWrite(LED_STATUS, HIGH);
      Serial.println("[FSR] ✓ Người dùng cầm gậy");
      Serial.printf("[DEBUG] Giá trị FSR: %d (< %d)\n", fsrValue, FSR_THRESHOLD);
    }
    lastTouchTime = now;
  } else {
    if (userHolding) {
      userHolding = false;
      digitalWrite(LED_STATUS, LOW);
      Serial.println("[FSR] ⚠️ Người dùng đã thả gậy");
      Serial.printf("[DEBUG] Bắt đầu đếm thời gian (%.1f giây)\n", NO_TOUCH_TIMEOUT / 1000.0);
    }
    
    unsigned long timeWithoutTouch = now - lastTouchTime;
    
    if (timeWithoutTouch > NO_TOUCH_TIMEOUT && !forgetAlertSent) {
      Serial.println("\n╔════════════════════════════════════╗");
      Serial.println("║  ⚠️  GẬY CÓ THỂ BỊ BỎ QUÊN!  ⚠️   ║");
      Serial.println("╚════════════════════════════════════╝");
      Serial.printf("[DEBUG] Thời gian bỏ gậy: %.1f giây\n", timeWithoutTouch / 1000.0);
      
      forgetAlertSent = true;
      currentPattern = BUZZER_FORGET;
      
      sendForgetAlert();
    } else if (timeWithoutTouch % 1000 < 100 && timeWithoutTouch < NO_TOUCH_TIMEOUT) {
      Serial.printf("[FSR] Thời gian bỏ gậy: %.1f/%.1f giây\n", 
                    timeWithoutTouch / 1000.0, 
                    NO_TOUCH_TIMEOUT / 1000.0);
    }
  }
}

