void setupHardware() {
  Wire.begin(MPU_SDA, MPU_SCL);
  Serial.print("[INIT] MPU6050... ");
  mpu.initialize();
  Serial.println(mpu.testConnection() ? "OK" : "FAIL");

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  Serial.println("[INIT] HC-SR05... OK");

  pinMode(FORCE_SENSOR_PIN, INPUT);
  Serial.println("[INIT] FSR402... OK");

  pinMode(BUTTON_SOS, INPUT_PULLUP);
  pinMode(BUTTON_FORGET_TOGGLE, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(BUTTON_SOS), isrSOSButton, FALLING);
  attachInterrupt(digitalPinToInterrupt(BUTTON_FORGET_TOGGLE), isrToggleButton, FALLING);
  Serial.println("[INIT] Buttons (Interrupt)... OK");

  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(LED_STATUS, OUTPUT);
  pinMode(LED_FORGET_MODE, OUTPUT);
  pinMode(LED_GPS_STATUS, OUTPUT);
  
  digitalWrite(BUZZER_PIN, LOW);
  digitalWrite(LED_STATUS, LOW);
  digitalWrite(LED_FORGET_MODE, forgetModeEnabled ? HIGH : LOW);
  digitalWrite(LED_GPS_STATUS, LOW);
  
  Serial.println("[INIT] Buzzer & LED... OK");

  gpsSerial.begin(9600, SERIAL_8N1, GPS_RX, GPS_TX);
  Serial.println("[INIT] GPS Neo-6M... OK");

  simSerial.begin(115200, SERIAL_8N1, SIM_RX, SIM_TX);
  Serial.println("[INIT] SIM7600X... OK");
  initSIM7600();
}

