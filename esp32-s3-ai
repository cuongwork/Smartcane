void handleGeofenceAlert(char* json) {
  StaticJsonDocument<512> doc;
  DeserializationError error = deserializeJson(doc, json);
  
  if (error) {
    Serial.println("⚠️ Geofence JSON parse error");
    return;
  }
  
  String alertType = doc["alertType"] | "";
  String geofenceName = doc["geofenceName"] | "Unknown";
  
  Serial.println("\n╔════════════════════════════════════════╗");
  Serial.println("║      GEOFENCE ALERT RECEIVED           ║");
  Serial.println("╠════════════════════════════════════════╣");
  
  if (alertType == "GEOFENCE_BREACH") {
    Serial.println("║ 🚨 LEFT SAFE ZONE!");
    Serial.printf("║ Zone: %s\n", geofenceName.c_str());
    Serial.println("╚════════════════════════════════════════╝");
    currentPattern = BUZZER_GEOFENCE_BREACH;
    buzzerRepeatCount = 5; // FIXED: Set repeat count
    
  } else if (alertType == "GEOFENCE_RETURN") {
    Serial.println("║ ✅ RETURNED TO SAFE ZONE");
    Serial.printf("║ Zone: %s\n", geofenceName.c_str());
    Serial.println("╚════════════════════════════════════════╝");
    currentPattern = BUZZER_GEOFENCE_RETURN;
    buzzerRepeatCount = 1;
    
  } else if (alertType == "GEOFENCE_DWELL") {
    Serial.println("║ ⏱️ STAYING TOO LONG IN ZONE");
    Serial.printf("║ Zone: %s\n", geofenceName.c_str());
    Serial.println("╚════════════════════════════════════════╝");
    currentPattern = BUZZER_GEOFENCE_DWELL;
    buzzerRepeatCount = 3;
  }
}

// =====================================================================
// TASK 1: CRITICAL (Core 1)
// =====================================================================

void taskCritical(void *param) {
  TickType_t lastWake = xTaskGetTickCount();
  const TickType_t freq = pdMS_TO_TICKS(50);

  for (;;) {
    handleButtons();
    processSafety();
    checkForgetMode();
    vTaskDelayUntil(&lastWake, freq);
  }
}

