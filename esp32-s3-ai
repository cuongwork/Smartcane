void blinkLED(int pin, int times, int delayMs) {
  for (int i = 0; i < times; i++) {
    digitalWrite(pin, HIGH);
    delay(delayMs);
    digitalWrite(pin, LOW);
    delay(delayMs);
  }
}

// =====================================================================
// SIM7600 HELPER FUNCTIONS - IMPROVED
// =====================================================================

bool waitForSIMResponse(const char* expected, unsigned long timeout) {
  unsigned long start = millis();
  String response = "";
  
  while (millis() - start < timeout) {
    while (simSerial.available()) {
      char c = simSerial.read();
      response += c;
      Serial.print(c);
      
      if (response.indexOf(expected) != -1) {
        return true;
      }
      
      if (response.indexOf("ERROR") != -1) {
        Serial.println("\n[SIM] Error detected in response");
        return false;
      }
    }
    delay(10);
  }
  
  Serial.println("\n[SIM] Timeout waiting for: " + String(expected));
  return false;
}

bool sendSIMCommand(const char* cmd, const char* expectedResp, unsigned long timeout) {
  Serial.print("[SIM] Sending: ");
  Serial.println(cmd);
  
  simSerial.println(cmd);
  
  if (expectedResp != NULL) {
    return waitForSIMResponse(expectedResp, timeout);
  }
  
  delay(100);
  return true;
}

