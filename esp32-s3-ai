// =====================================================================
// XỬ LÝ SOS KHẨN CẤP
// =====================================================================

void handleSOSEmergency() {
  // Kiểm tra xem SOS có còn active không
  if (!sosActive) {
    Serial.println("[SOS] ⚠️ SOS đã bị hủy, bỏ qua gửi tin");
    return;
  }
  
  Serial.println("\n[SOS] ═══ BẮT ĐẦU CHUỖI KHẨN CẤP ═══");
  
  if (xSemaphoreTake(simMutex, portMAX_DELAY) == pdTRUE) {
    // Kiểm tra lại trạng thái SOS trước khi gọi
    if (!sosActive) {
      Serial.println("[SOS] ⚠️ SOS bị hủy trong lúc xử lý");
      xSemaphoreGive(simMutex);
      return;
    }
    
    // Serial.println("[SOS] 📞 Đang gọi điện...");
    // simSerial.print("ATD");
    // simSerial.print(EMERGENCY_PHONE);
    // simSerial.println(";");
    // delay(30000);
    // simSerial.println("ATH");
    
    Serial.println("[SOS] 💬 Đang gửi SMS...");
    sendSIMCommand("AT+CMGF=1", "OK", SIM_CMD_TIMEOUT);
    
    String cmgsCmd = "AT+CMGS=\"" + String(EMERGENCY_PHONE) + "\"";
    simSerial.println(cmgsCmd);
    delay(500);
    
    char smsContent[200];
    snprintf(smsContent, sizeof(smsContent),
             "CANH BAO KHAN CAP!\nNguoi dung can giup do.\nToa do: https://maps.google.com/?q=%.6f,%.6f",
             latitude, longitude);
    simSerial.print(smsContent);
    simSerial.write(26);
    
    waitForSIMResponse("OK", SIM_CMD_TIMEOUT);
    
    // Kiểm tra lại trạng thái SOS trước khi gửi HTTP
    if (!sosActive) {
      Serial.println("[SOS] ⚠️ SOS bị hủy sau khi gửi SMS");
      xSemaphoreGive(simMutex);
      return;
    }
    
    Serial.println("[SOS] 🌐 Đang gửi HTTP Alert...");
    StaticJsonDocument<256> doc;
    doc["type"] = "sos_emergency";
    doc["deviceToken"] = DEVICE_TOKEN;
    doc["lat"] = latitude;
    doc["lng"] = longitude;
    doc["time"] = millis();
    doc["priority"] = "critical";
    doc["active"] = sosActive; // Thêm trạng thái active
    
    String json;
    serializeJson(doc, json);
    sendHTTPViaSIM(json);
    
    xSemaphoreGive(simMutex);
  }
  
  Serial.println("[SOS] ═══ HOÀN TẤT ═══\n");
}

