// =====================================================================
// ĐIỀU KHIỂN BUZZER - NON-BLOCKING VERSION
// =====================================================================

void controlBuzzer() {
  unsigned long now = millis();
  
  switch (currentPattern) {
    case BUZZER_OFF:
      digitalWrite(BUZZER_PIN, LOW);
      buzzerState = false;
      break;
      
    case BUZZER_SOS:
    case BUZZER_FALL:
      if (now - lastBuzzerToggle > 200) {
        buzzerState = !buzzerState;
        digitalWrite(BUZZER_PIN, buzzerState);
        lastBuzzerToggle = now;
      }
      break;
      
    case BUZZER_FORGET:
      if (buzzerState && (now - lastBuzzerToggle > 1000)) {
        buzzerState = false;
        digitalWrite(BUZZER_PIN, LOW);
        lastBuzzerToggle = now;
      } else if (!buzzerState && (now - lastBuzzerToggle > 500)) {
        buzzerState = true;
        digitalWrite(BUZZER_PIN, HIGH);
        lastBuzzerToggle = now;
      }
      break;
      
    case BUZZER_OBSTACLE_CRITICAL:
      if (now - lastBuzzerToggle > 100) {
        buzzerState = !buzzerState;
        digitalWrite(BUZZER_PIN, buzzerState);
        lastBuzzerToggle = now;
      }
      break;
      
    case BUZZER_OBSTACLE_WARNING:
      if (buzzerState && (now - lastBuzzerToggle > 200)) {
        buzzerState = false;
        digitalWrite(BUZZER_PIN, LOW);
        lastBuzzerToggle = now;
      } else if (!buzzerState && (now - lastBuzzerToggle > 800)) {
        buzzerState = true;
        digitalWrite(BUZZER_PIN, HIGH);
        lastBuzzerToggle = now;
      }
      break;
      
    // FIXED: Non-blocking geofence patterns
    case BUZZER_GEOFENCE_BREACH:
      if (buzzerRepeatCount > 0) {
        if (buzzerState && (now - lastBuzzerToggle > 200)) {
          buzzerState = false;
          digitalWrite(BUZZER_PIN, LOW);
          lastBuzzerToggle = now;
          buzzerRepeatCount--;
        } else if (!buzzerState && (now - lastBuzzerToggle > 200)) {
          buzzerState = true;
          digitalWrite(BUZZER_PIN, HIGH);
          lastBuzzerToggle = now;
        }
      } else {
        currentPattern = BUZZER_OFF;
        digitalWrite(BUZZER_PIN, LOW);
      }
      break;
      
    case BUZZER_GEOFENCE_RETURN:
      if (buzzerRepeatCount > 0) {
        digitalWrite(BUZZER_PIN, HIGH);
        buzzerRepeatCount = 0;
        lastBuzzerToggle = now;
      } else if (now - lastBuzzerToggle > 500) {
        digitalWrite(BUZZER_PIN, LOW);
        currentPattern = BUZZER_OFF;
      }
      break;
      
    case BUZZER_GEOFENCE_DWELL:
      if (buzzerRepeatCount > 0) {
        if (buzzerState && (now - lastBuzzerToggle > 100)) {
          buzzerState = false;
          digitalWrite(BUZZER_PIN, LOW);
          lastBuzzerToggle = now;
          buzzerRepeatCount--;
        } else if (!buzzerState && (now - lastBuzzerToggle > 100)) {
          buzzerState = true;
          digitalWrite(BUZZER_PIN, HIGH);
          lastBuzzerToggle = now;
        }
      } else {
        currentPattern = BUZZER_OFF;
        digitalWrite(BUZZER_PIN, LOW);
      }
      break;
      
    case BUZZER_CONFIRM_ON:
      if (buzzerRepeatCount > 0) {
        digitalWrite(BUZZER_PIN, HIGH);
        lastBuzzerToggle = now;
        buzzerRepeatCount = 0;
      } else if (now - lastBuzzerToggle > 100) {
        digitalWrite(BUZZER_PIN, LOW);
        currentPattern = BUZZER_OFF;
      }
      break;
      
    case BUZZER_CONFIRM_OFF:
      if (buzzerRepeatCount > 0) {
        if (buzzerState && (now - lastBuzzerToggle > 100)) {
          buzzerState = false;
          digitalWrite(BUZZER_PIN, LOW);
          lastBuzzerToggle = now;
          buzzerRepeatCount--;
        } else if (!buzzerState && (now - lastBuzzerToggle > 100)) {
          buzzerState = true;
          digitalWrite(BUZZER_PIN, HIGH);
          lastBuzzerToggle = now;
        }
      } else {
        currentPattern = BUZZER_OFF;
        digitalWrite(BUZZER_PIN, LOW);
      }
      break;
  }
}

