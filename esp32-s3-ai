// =====================================================================
// PHÁT HIỆN TÉ NGÃ
// =====================================================================

void detectFall() {
  if (xSemaphoreTake(i2cMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
    int16_t ax, ay, az;
    mpu.getAcceleration(&ax, &ay, &az);
    xSemaphoreGive(i2cMutex);

    float accelX = ax / 16384.0 * 9.81;
    float accelY = ay / 16384.0 * 9.81;
    float accelZ = az / 16384.0 * 9.81;
    float totalAccel = sqrt(accelX*accelX + accelY*accelY + accelZ*accelZ);

    if (totalAccel > FALL_ACCEL_THRESHOLD && !fallDetected) {
      fallDetected = true;
      fallStartTime = millis();
      Serial.println("[FALL] ⚠️ Phát hiện va đập mạnh!");
      Serial.printf("[DEBUG] Gia tốc: %.2f m/s²\n", totalAccel);
    }

    if (fallDetected && !fallAlertSent) {
      unsigned long timeSinceFall = millis() - fallStartTime;
      
      if (timeSinceFall > FALL_CONFIRM_TIME) {
        if (abs(totalAccel - 9.81) < 2.0) {
          Serial.println("[FALL] ⚠️⚠️ XÁC NHẬN TÉ NGÃ - Người dùng nằm yên!");
          Serial.printf("[DEBUG] Gia tốc hiện tại: %.2f m/s²\n", totalAccel);
          
          fallAlertSent = true;
          
          // Chỉ kích hoạt SOS nếu chưa bật
          if (!sosActive) {
            currentPattern = BUZZER_FALL;
            sendFallSMS();
            
            bool sosFlag = true;
            xQueueSend(sosQueue, &sosFlag, 0);
          }
        } else {
          Serial.println("[FALL] ✓ Người dùng đã đứng dậy (trong thời gian chờ)");
          Serial.printf("[DEBUG] Gia tốc: %.2f m/s²\n", totalAccel);
          fallDetected = false;
          fallAlertSent = false;
        }
      }
    }

    if (fallAlertSent && abs(totalAccel - 9.81) > 3.0) {
      Serial.println("[FALL] ✓ Người dùng đã đứng dậy (sau khi té)");
      Serial.printf("[DEBUG] Gia tốc: %.2f m/s²\n", totalAccel);
      fallDetected = false;
      fallAlertSent = false;
      
      // Chỉ tắt buzzer nếu không có SOS active
      if (!sosActive && currentPattern == BUZZER_FALL) {
        currentPattern = BUZZER_OFF;
      }
    }
  }
}

