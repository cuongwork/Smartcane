// =====================================================================
// PHÁT HIỆN VẬT CẢN (với Filter)
// =====================================================================

void detectObstacle() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH, 30000);
  float rawDistance = duration * 0.034 / 2;
  
  // Áp dụng Moving Average Filter
  float distance = distanceFilter.update(rawDistance);

  if (distance > 0 && distance < OBSTACLE_CRITICAL) {
    if (currentPattern != BUZZER_SOS && currentPattern != BUZZER_FALL 
        && currentPattern != BUZZER_FALL_PRE_ALERT) {
      currentPattern = BUZZER_OBSTACLE_CRITICAL;
    }
    currentObstacleLevel = 2;
  } else if (distance >= OBSTACLE_CRITICAL && distance < OBSTACLE_WARNING) {
    if (currentPattern != BUZZER_SOS && currentPattern != BUZZER_FALL
        && currentPattern != BUZZER_FALL_PRE_ALERT) {
      currentPattern = BUZZER_OBSTACLE_WARNING;
    }
    currentObstacleLevel = 1;
  } else {
    if (currentPattern == BUZZER_OBSTACLE_CRITICAL || 
        currentPattern == BUZZER_OBSTACLE_WARNING) {
      currentPattern = BUZZER_OFF;
    }
    currentObstacleLevel = 0;
  }
}

// =====================================================================
// KIỂM TRA CHỐNG QUÊN
// =====================================================================

void checkForgetMode() {
  if (!forgetModeEnabled) return;

  int fsrValue = analogRead(FORCE_SENSOR_PIN);
  unsigned long now = millis();

  if (fsrValue < FSR_THRESHOLD) {
    if (!userHolding) {
      userHolding = true;
      forgetAlertSent = false;
      digitalWrite(LED_STATUS, HIGH);
      Serial.println("[FSR] ✓ Người dùng cầm gậy");
      if (currentPattern == BUZZER_FORGET) {
          currentPattern = BUZZER_OFF;
      }
    }
    lastTouchTime = now;
  } else {
    if (userHolding) {
      userHolding = false;
      digitalWrite(LED_STATUS, LOW);
      Serial.println("[FSR] ⚠️ Người dùng đã thả gậy");
    }
    
    unsigned long timeWithoutTouch = now - lastTouchTime;
    
    if (timeWithoutTouch > NO_TOUCH_TIMEOUT && !forgetAlertSent) {
      Serial.println("\n╔════════════════════════════════════╗");
      Serial.println("║  ⚠️  GẬY CÓ THỂ BỊ BỎ QUÊN!  ⚠️   ║");
      Serial.println("╚════════════════════════════════════╝");
      
      forgetAlertSent = true;
      currentPattern = BUZZER_FORGET;
      sendAlertPacketToS3(PACKET_FORGET_ALERT, "Cane Forgotten!");
      sendForgetAlert();
    }
  }
}

void sendForgetAlert() {
  Serial.println("[FORGET] Đang gửi cảnh báo...");
  
  StaticJsonDocument<256> doc;
  doc["type"] = "forget_alert";
  doc["deviceToken"] = DEVICE_TOKEN;
  doc["lat"] = latitude;
  doc["lng"] = longitude;
  doc["timestamp"] = getRealTimestamp();
  doc["message"] = "Gậy có thể bị bỏ quên";
  
  String json;
  serializeJson(doc, json);
  
  if (wifiConnected && WiFi.status() == WL_CONNECTED) {
    sendHTTPViaWiFi(json, GPS_SERVER_URL);
  }
}

// =====================================================================
// TASK 2: COMMUNICATION (Core 0) - Priority 1
// =====================================================================

void taskCommunication(void *param) {
  TickType_t lastWake = xTaskGetTickCount();
  const TickType_t freq = pdMS_TO_TICKS(1000);

  for (;;) {
    updateGPS();
    
    bool sosFlag;
    if (xQueueReceive(sosQueue, &sosFlag, 0) == pdTRUE) {
      handleSOSEmergency();
    }

    vTaskDelayUntil(&lastWake, freq);
  }
}

// =====================================================================
// CẬP NHẬT GPS
// =====================================================================

void updateGPS() {
  while (gpsSerial.available() > 0) {
    if (gps.encode(gpsSerial.read())) {
      if (xSemaphoreTake(gpsMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
        if (gps.location.isValid()) {
          latitude = gps.location.lat();
          longitude = gps.location.lng();
          gpsSpeed = gps.speed.kmph();
          gpsSatellites = gps.satellites.value();
          gpsValid = true;
          digitalWrite(LED_GPS_STATUS, HIGH);
        } else {
          gpsValid = false;
          digitalWrite(LED_GPS_STATUS, LOW);
        }
        xSemaphoreGive(gpsMutex);
      }
    }
  }
}

// =====================================================================
// TASK 3: GPS TRACKER (Core 0) - Priority 2
// =====================================================================

void taskGPSTracker(void *param) {
  TickType_t lastWake = xTaskGetTickCount();
  const TickType_t freq = pdMS_TO_TICKS(GPS_SEND_INTERVAL);

  for (;;) {
    // Dừng gửi GPS nếu SOS đang diễn ra
    if (!simSOSPriority && wifiConnected && WiFi.status() == WL_CONNECTED ) {
      sendGPSLocation();
    }

    vTaskDelayUntil(&lastWake, freq);
  }
}

// =====================================================================
// GỬI GPS LOCATION QUA WiFi
// =====================================================================

void sendGPSLocation() {
  if (xSemaphoreTake(gpsMutex, pdMS_TO_TICKS(50)) == pdTRUE) {
    StaticJsonDocument<512> doc;
    doc["deviceToken"] = DEVICE_TOKEN;
    doc["timestamp"] = getRealTimestamp();
    
    JsonObject gpsObj = doc.createNestedObject("gps");
    if (gpsValid) {
      gpsObj["latitude"] = latitude;
      gpsObj["longitude"] = longitude;
      gpsObj["speed"] = gpsSpeed;
      gpsObj["satellites"] = gpsSatellites;
      gpsObj["type"] = "REAL"; // Gắn tag để bạn biết là tọa độ thật
    } else {
      gpsObj["latitude"] = MOCK_LAT;
      gpsObj["longitude"] = MOCK_LNG;
      gpsObj["speed"] = 0.0;
      gpsObj["satellites"] = 0;
      gpsObj["type"] = "DEMO"; // Gắn tag để biết là tọa độ giả lập
    }
    
    JsonObject network = doc.createNestedObject("network");
    network["type"] = "wifi";
    network["signalStrength"] = WiFi.RSSI();
    
    JsonObject status = doc.createNestedObject("status");
    status["sos"] = sosActive;
    status["lost"] = !userHolding && forgetModeEnabled;
    
    if (gpsSpeed < 1.0) {
      status["motion"] = "STOPPED";
    } else if (gpsSpeed < 5.0) {
      status["motion"] = "WALKING";
    } else if (gpsSpeed < 15.0) {
      status["motion"] = "FAST_WALKING";
    } else {
      status["motion"] = "DRIVING";
    }
    
    xSemaphoreGive(gpsMutex);
    
    String jsonOutput;
    serializeJson(doc, jsonOutput);
    
    sendHTTPViaWiFi(jsonOutput, GPS_SERVER_URL);
  }
}

