// =====================================================================
// SIM STATE MACHINE (NON-BLOCKING)
// =====================================================================

void processSIMStateMachine() {
  // Kiểm tra timeout (tránh deadlock)
  unsigned long now = millis();
  if (simState != SIM_IDLE && (now - simStateStartTime) > 30000) {
    Serial.println("[SIM] ⚠️ Timeout! Reset state");
    simState = SIM_IDLE;
    if (xSemaphoreTake(simMutex, 0) == pdTRUE) {
      xSemaphoreGive(simMutex);
    }
    return;
  }
  
  switch (simState) {
    case SIM_IDLE:
      // Nếu có SOS priority, xử lý ngay
      if (simSOSPriority) {
        if (xSemaphoreTake(simMutex, pdMS_TO_TICKS(100)) == pdTRUE) {
          Serial.println("[SIM] → SENDING_SMS_INIT (SOS)");
          simSerial.println("AT+CMGF=1");
          simState = SIM_SENDING_SMS_INIT;
          simStateStartTime = now;
        }
      }
      break;
      
    case SIM_SENDING_SMS_INIT:
      if ((now - simStateStartTime) > 1000) {
        Serial.println("[SIM] → SENDING_SMS_NUMBER");
        simSerial.print("AT+CMGS=\"");
        simSerial.print(EMERGENCY_PHONE);
        simSerial.println("\"");
        simState = SIM_SENDING_SMS_NUMBER;
        simStateStartTime = now;
      }
      break;
      
    case SIM_SENDING_SMS_NUMBER:
      if ((now - simStateStartTime) > 1000) {
        Serial.println("[SIM] → SENDING_SMS_CONTENT");
        
        char smsContent[200];
        if (fallState == FALL_CONFIRMED) {
          snprintf(smsContent, sizeof(smsContent),
                   "CANH BAO TE NGA!\nNguoi dung da te.\nVi tri: https://maps.google.com/?q=%.6f,%.6f",
                   latitude, longitude);
        } else {
          snprintf(smsContent, sizeof(smsContent),
                   "CANH BAO KHAN CAP!\nNguoi dung can giup do.\nVi tri: https://maps.google.com/?q=%.6f,%.6f",
                   latitude, longitude);
        }
        
        simSerial.print(smsContent);
        simSerial.write(26);
        simState = SIM_SENDING_SMS_WAIT;
        simStateStartTime = now;
      }
      break;
      
    case SIM_SENDING_SMS_WAIT:
      if ((now - simStateStartTime) > 5000) {
        while(simSerial.available()) simSerial.read();
        Serial.println("[SIM] ✓ SMS Sent!");
        simState = SIM_IDLE;
        simSOSPriority = false;
        xSemaphoreGive(simMutex);
      }
      break;
      
    default:
      simState = SIM_IDLE;
      break;
  }
}

// =====================================================================
// XỬ LÝ SOS KHẨN CẤP
// =====================================================================

void handleSOSEmergency() {
  Serial.println("\n[SOS] ═══ BẮT ĐẦU CHUỖI KHẨN CẤP ═══");
  
  // Đánh dấu SOS priority để Task SIM xử lý
  simSOSPriority = true;
  sosActive = true;
  
  // Gửi HTTP Alert qua WiFi (không chờ SIM)
  if (wifiConnected) {
    StaticJsonDocument<256> doc;
    doc["type"] = "sos_emergency";
    doc["deviceToken"] = DEVICE_TOKEN;
    doc["lat"] = latitude;
    doc["lng"] = longitude;
    doc["timestamp"] = getRealTimestamp();
    doc["priority"] = "critical";
    
    String json;
    serializeJson(doc, json);
    sendHTTPViaWiFi(json, GPS_SERVER_URL);
  }
  
  sendAlertPacketToS3(PACKET_FALL_ALERT, "SOS Emergency!");
  
  Serial.println("[SOS] ✓ Alert sent via WiFi");
  Serial.println("[SOS] Task SIM đang xử lý SMS...");
}

// =====================================================================
// GỬI HTTP QUA WIFI
// =====================================================================

void sendHTTPViaWiFi(String jsonData, const char* url) {
    if (WiFi.status() == WL_CONNECTED) {
        HTTPClient http;
        WiFiClient client; 
        
        http.begin(client, url);
        
        // --- PHẦN CẦN THÊM VÀO ---
        http.addHeader("Content-Type", "application/json");
        
        // Thêm Authorization để sửa lỗi 403
        String authHeader = "Bearer " + String(DEVICE_TOKEN);
        http.addHeader("Authorization", authHeader);
        
        // Thêm User-Agent để tránh bị Nginx chặn
        http.addHeader("User-Agent", "ESP32-Smart-Cane-V3.2");
        // -------------------------
        
        int httpCode = http.POST(jsonData);
        
        if (httpCode > 0) {
            Serial.printf("[HTTP] Thanh cong, ma phan hoi: %d\n", httpCode);
            String payload = http.getString();
            Serial.println(payload);
        } else {
            Serial.printf("[HTTP] That bai, loi: %s\n", http.errorToString(httpCode).c_str());
        }
        http.end();
    }
}

