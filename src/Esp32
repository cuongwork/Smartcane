// =====================================================================
// ĐIỀU KHIỂN BUZZER
// =====================================================================

void controlBuzzer() {
  unsigned long now = millis();
  
  switch (currentPattern) {
    case BUZZER_OFF:
      digitalWrite(BUZZER_PIN, LOW);
      buzzerState = false;
      break;
      
    case BUZZER_SOS:
    case BUZZER_FALL:
      if (now - lastBuzzerToggle > 200) {
        buzzerState = !buzzerState;
        digitalWrite(BUZZER_PIN, buzzerState);
        lastBuzzerToggle = now;
      }
      break;
      
    case BUZZER_FALL_PRE_ALERT:
      // Bíp nhanh 150ms để cảnh báo
      if (now - lastBuzzerToggle > 150) {
        buzzerState = !buzzerState;
        digitalWrite(BUZZER_PIN, buzzerState);
        lastBuzzerToggle = now;
      }
      break;
      
    case BUZZER_FORGET:
      if (buzzerState && (now - lastBuzzerToggle > 1000)) {
        buzzerState = false;
        digitalWrite(BUZZER_PIN, LOW);
        lastBuzzerToggle = now;
      } else if (!buzzerState && (now - lastBuzzerToggle > 500)) {
        buzzerState = true;
        digitalWrite(BUZZER_PIN, HIGH);
        lastBuzzerToggle = now;
      }
      break;
      
    case BUZZER_OBSTACLE_CRITICAL:
      if (now - lastBuzzerToggle > 100) {
        buzzerState = !buzzerState;
        digitalWrite(BUZZER_PIN, buzzerState);
        lastBuzzerToggle = now;
      }
      break;
      
    case BUZZER_OBSTACLE_WARNING:
      if (now - lastBuzzerToggle > 300) {
        buzzerState = !buzzerState;
        digitalWrite(BUZZER_PIN, buzzerState);
        lastBuzzerToggle = now;
      }
      break;
      
    case BUZZER_CONFIRM_ON:
      digitalWrite(BUZZER_PIN, HIGH);
      vTaskDelay(pdMS_TO_TICKS(100));
      digitalWrite(BUZZER_PIN, LOW);
      currentPattern = BUZZER_OFF;
      break;
      
    case BUZZER_CONFIRM_OFF:
      for (int i = 0; i < 2; i++) {
        digitalWrite(BUZZER_PIN, HIGH);
        vTaskDelay(pdMS_TO_TICKS(100));
        digitalWrite(BUZZER_PIN, LOW);
        vTaskDelay(pdMS_TO_TICKS(100));
      }
      currentPattern = BUZZER_OFF;
      break;
  }
}

// =====================================================================
// UART BINARY PROTOCOL - HELPER FUNCTIONS
// =====================================================================

uint8_t calculateChecksum(uint8_t* data, size_t length) {
  uint8_t checksum = 0;
  for (size_t i = 0; i < length; i++) {
    checksum ^= data[i];
  }
  return checksum;
}

void sendGPSPacketToS3() {
  if (xSemaphoreTake(uartMutex, pdMS_TO_TICKS(50)) == pdTRUE) {
    GPSLocationPacket packet;
    packet.startByte = PACKET_START_BYTE;
    packet.packetType = PACKET_GPS_LOCATION;
    packet.packetSize = sizeof(packet) - 4;
    
    packet.latitude = latitude;
    packet.longitude = longitude;
    packet.speed = gpsSpeed;
    packet.satellites = gpsSatellites;
    packet.gpsValid = gpsValid ? 1 : 0;
    packet.timestamp = millis();
    
    packet.checksum = calculateChecksum(
      ((uint8_t*)&packet) + 1, 
      sizeof(packet) - 3
    );
    
    packet.endByte = PACKET_END_BYTE;
    
    Serial.write((uint8_t*)&packet, sizeof(packet));
    Serial.flush();
    
    xSemaphoreGive(uartMutex);
  }
}

void sendStatusPacketToS3() {
  if (xSemaphoreTake(uartMutex, pdMS_TO_TICKS(50)) == pdTRUE) {
    StatusUpdatePacket packet;
    packet.startByte = PACKET_START_BYTE;
    packet.packetType = PACKET_STATUS_UPDATE;
    packet.packetSize = sizeof(packet) - 4;
    
    packet.sosActive = sosActive ? 1 : 0;
    packet.userHolding = userHolding ? 1 : 0;
    packet.forgetMode = forgetModeEnabled ? 1 : 0;
    
    if (gpsSpeed < 1.0) {
      packet.motionStatus = MOTION_STOPPED;
    } else if (gpsSpeed < 5.0) {
      packet.motionStatus = MOTION_WALKING;
    } else if (gpsSpeed < 15.0) {
      packet.motionStatus = MOTION_FAST_WALKING;
    } else {
      packet.motionStatus = MOTION_DRIVING;
    }
    
    packet.wifiRSSI = wifiConnected ? WiFi.RSSI() : -100;
    packet.batteryLevel = 85;
    packet.timestamp = millis();
    
    packet.checksum = calculateChecksum(
      ((uint8_t*)&packet) + 1,
      sizeof(packet) - 3
    );
    
    packet.endByte = PACKET_END_BYTE;
    
    Serial.write((uint8_t*)&packet, sizeof(packet));
    Serial.flush();
    
    xSemaphoreGive(uartMutex);
  }
}

void sendAlertPacketToS3(PacketType type, const char* msg) {
  if (xSemaphoreTake(uartMutex, pdMS_TO_TICKS(50)) == pdTRUE) {
    AlertPacket packet;
    packet.startByte = PACKET_START_BYTE;
    packet.packetType = type;
    packet.packetSize = sizeof(packet) - 4;
    
    packet.latitude = latitude;
    packet.longitude = longitude;
    packet.gpsValid = gpsValid ? 1 : 0;
    
    strncpy(packet.message, msg, 15);
    packet.message[15] = '\0';
    
    packet.timestamp = millis();
    
    packet.checksum = calculateChecksum(
      ((uint8_t*)&packet) + 1,
      sizeof(packet) - 3
    );
    
    packet.endByte = PACKET_END_BYTE;
    
    Serial.write((uint8_t*)&packet, sizeof(packet));
    Serial.flush();
    
    xSemaphoreGive(uartMutex);
  }
}

