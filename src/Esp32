void handleButtons() {
  ButtonEvent evt;
  
  while (xQueueReceive(buttonEventQueue, &evt, 0) == pdTRUE) {
    
if (evt.buttonType == 0) { // Nút SOS
    if (!sosActive) { 
        // LẦN NHẤN ĐẦU TIÊN: Kích hoạt
        sosActive = true; 
        currentPattern = BUZZER_SOS;
        digitalWrite(LED_STATUS, HIGH);
        
        // Gọi hàm gửi cảnh báo trực tiếp (hoặc bật flag cho Task)
        // Không dùng xQueueSend nữa để tránh tích tụ lệnh trong RAM
        handleSOSEmergency(); 
        Serial.println("[SOS] Đã gửi cảnh báo duy nhất một lần.");
    } 
    else {
        // ĐANG TRONG TRẠNG THÁI SOS: Kiểm tra nhấn giữ 3s để tắt
        unsigned long startCheck = millis();
        bool confirmed = false;

        while (digitalRead(BUTTON_SOS) == LOW) {
            if (millis() - startCheck >= 3000) {
                confirmed = true;
                break;
            }
            vTaskDelay(pdMS_TO_TICKS(20));
        }

        if (confirmed) {
            sosActive = false; // Reset trạng thái để có thể gửi lần sau
            currentPattern = BUZZER_CONFIRM_OFF;
            digitalWrite(LED_STATUS, LOW);
            Serial.println("[SOS] ĐÃ TẮT THỦ CÔNG .");
        }
    }
} else if (evt.buttonType == 1) {  // Toggle Button
      forgetModeEnabled = !forgetModeEnabled;
      preferences.putBool("forgetMode", forgetModeEnabled);
      
      digitalWrite(LED_FORGET_MODE, forgetModeEnabled ? HIGH : LOW);
      currentPattern = forgetModeEnabled ? BUZZER_CONFIRM_ON : BUZZER_CONFIRM_OFF;
      
      Serial.println("\n╔════════════════════════════════════╗");
      Serial.printf("║  CHỐNG QUÊN: %-22s║\n", forgetModeEnabled ? "BẬT ✓" : "TẮT ✗");
      Serial.println("╚════════════════════════════════════╝");
      
      if (!forgetModeEnabled) {
        forgetAlertSent = false;
        lastTouchTime = millis();
        if (currentPattern == BUZZER_FORGET) {
          currentPattern = BUZZER_OFF;
      }
      }
      
      toggleProcessing = true;
      vTaskDelay(pdMS_TO_TICKS(200));
      toggleProcessing = false;
      
    } else if (evt.buttonType == 2) {  // Cancel Fall Alert
      if (fallState == FALL_PRE_ALERT) {
        Serial.println("\n[FALL] ✓ Người dùng hủy cảnh báo té ngã!");
        fallCancelled = true;
        fallState = FALL_IDLE;
        currentPattern = BUZZER_OFF;
      }
    }
  }
}

