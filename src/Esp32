void IRAM_ATTR isrSOSButton() {
  unsigned long now = millis();
  if ((now - lastSOSPress > DEBOUNCE_DELAY) && !sosProcessing) {
    ButtonEvent evt = {0, now};
    xQueueSendFromISR(buttonEventQueue, &evt, NULL);
    lastSOSPress = now;
  }
}

void IRAM_ATTR isrToggleButton() {
  unsigned long now = millis();
  if ((now - lastTogglePress > DEBOUNCE_DELAY) && !toggleProcessing) {
    ButtonEvent evt = {1, now};
    xQueueSendFromISR(buttonEventQueue, &evt, NULL);
    lastTogglePress = now;
  }
}

