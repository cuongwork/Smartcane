// =====================================================================
// SNTP TIME SYNC
// =====================================================================

void syncSNTP() {
  Serial.println("[SNTP] Đang đồng bộ thời gian...");
  configTime(GMT_OFFSET_SEC, DAYLIGHT_OFFSET_SEC, NTP_SERVER);
  
  int retries = 0;
  struct tm timeinfo;
  while (!getLocalTime(&timeinfo) && retries < 10) {
    delay(500);
    retries++;
  }
  
  if (retries < 10) {
    sntpSynced = true;
    Serial.println("[SNTP] ✓ Đồng bộ thành công!");
    Serial.printf("[SNTP] Thời gian: %02d:%02d:%02d\n", 
                  timeinfo.tm_hour, timeinfo.tm_min, timeinfo.tm_sec);
  } else {
    Serial.println("[SNTP] ✗ Không thể đồng bộ!");
  }
}

// =====================================================================
// REAL TIMESTAMP (GPS → SNTP → millis fallback)
// =====================================================================

String getRealTimestamp() {
  char timestamp[30];
  
  // Ưu tiên: Sử dụng SNTP Time (Đã config GMT+7)
  if (sntpSynced) {
    struct tm timeinfo;
    if (getLocalTime(&timeinfo)) {
      // Format: YYYY-MM-DDTHH:MM:SS (Local time, không có Z)
      strftime(timestamp, sizeof(timestamp), "%Y-%m-%dT%H:%M:%S", &timeinfo);
      return String(timestamp);
    }
  }
  
  // Fallback: Sử dụng millis() + tính toán thủ công
  unsigned long totalSeconds = millis() / 1000;
  int hours = 7 + ((totalSeconds / 3600) % 24);  // GMT+7
  int minutes = (totalSeconds / 60) % 60;
  int seconds = totalSeconds % 60;
  
  // Ngày cố định cho demo (NÊN THAY ĐỔI NẾU DÙNG THỰC TẾ)
  snprintf(timestamp, sizeof(timestamp), 
           "2025-01-06 %02d:%02d:%02d", hours, minutes, seconds);
  return String(timestamp);
}

// =====================================================================
// TASK 1: CRITICAL (Core 1) - Priority 3
// =====================================================================

void taskCritical(void *param) {
  TickType_t lastWake = xTaskGetTickCount();
  const TickType_t freq = pdMS_TO_TICKS(50);

  for (;;) {
    handleButtons();
    processSafety();
    checkForgetMode();
    vTaskDelayUntil(&lastWake, freq);
  }
}

