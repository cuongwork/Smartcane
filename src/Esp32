// =====================================================================
// PHÁT HIỆN TÉ NGÃ (IMPROVED với PRE_ALERT)
// =====================================================================

void detectFall() {
  if (xSemaphoreTake(i2cMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
    int16_t ax, ay, az, gx, gy, gz;
    mpu.getMotion6(&ax, &ay, &az, &gx, &gy, &gz);
    xSemaphoreGive(i2cMutex);

    if (ax == 0 && ay == 0 && az == 0) {
      Serial.println("[I2C] Bus Hang detected! Resetting...");
      Wire.begin(MPU_SDA, MPU_SCL); // Khởi động lại I2C
      mpu.initialize();
      return;
    }
    float accelX = ax / 16384.0;
    float accelY = ay / 16384.0;
    float accelZ = az / 16384.0;
    float rawAccel = sqrt(accelX*accelX + accelY*accelY + accelZ*accelZ);
    
    // Áp dụng Moving Average Filter
    float totalAccel = accelFilter.update(rawAccel);
    
    float pitch = atan2(accelY, sqrt(accelX*accelX + accelZ*accelZ)) * 180.0 / PI;
    float roll = atan2(-accelX, accelZ) * 180.0 / PI;
    float tiltAngle = sqrt(pitch*pitch + roll*roll);
    
    unsigned long now = millis();
    
    // Kiểm tra nút Cancel trong PRE_ALERT state
    if (fallState == FALL_PRE_ALERT) {
      if (digitalRead(BUTTON_SOS) == LOW || digitalRead(BUTTON_FORGET_TOGGLE) == LOW) {
        ButtonEvent cancelEvt = {2, now};
        xQueueSend(buttonEventQueue, &cancelEvt, 0);
      }
    }
    
    switch (fallState) {
      
      case FALL_IDLE:
        if (totalAccel < FREEFALL_THRESHOLD) {
          fallState = FALL_FREEFALL;
          fallStateStartTime = now;
          Serial.println("[FALL FSM] → FREEFALL");
          Serial.printf("[DEBUG] Gia tốc: %.2fg (filtered)\n", totalAccel);
        }
        break;
      
      case FALL_FREEFALL:
        if (totalAccel > IMPACT_THRESHOLD) {
          fallState = FALL_IMPACT;
          fallStateStartTime = now;
          Serial.println("[FALL FSM] → IMPACT");
          Serial.printf("[DEBUG] Va chạm: %.2fg\n", totalAccel);
        } 
        else if ((now - fallStateStartTime) > 500) {
          Serial.println("[FALL FSM] → IDLE (Timeout)");
          fallState = FALL_IDLE;
        }
        break;
      
      case FALL_IMPACT:
        if (tiltAngle > FALL_ANGLE_THRESHOLD) {
          fallState = FALL_PRE_ALERT;
          fallStateStartTime = now;
          fallCancelled = false;
          currentPattern = BUZZER_FALL_PRE_ALERT;
          
          Serial.println("\n╔════════════════════════════════════╗");
          Serial.println("║  ⚠️  CẢNH BÁO TÉ NGÃ (5s)  ⚠️      ║");
          Serial.println("║  Nhấn NÚT BẤT KỲ để HỦY!          ║");
          Serial.println("╚════════════════════════════════════╝");
          Serial.printf("[DEBUG] Góc: %.1f° - Nhấn nút để hủy!\n", tiltAngle);
        } else {
          Serial.println("[FALL FSM] → IDLE (Góc nhỏ)");
          fallState = FALL_IDLE;
        }
        break;
      
      case FALL_PRE_ALERT:
        // Chờ 5 giây, cho phép người dùng hủy
        if (fallCancelled) {
          fallState = FALL_IDLE;
          currentPattern = BUZZER_OFF;
          Serial.println("[FALL] Đã hủy cảnh báo!");
        }
        else if ((now - fallStateStartTime) > FALL_PRE_ALERT_TIME) {
          fallState = FALL_WAIT_CONFIRM;
          fallStateStartTime = now;
          Serial.println("[FALL FSM] → WAIT_CONFIRM (Không hủy)");
        }
        break;
      
      case FALL_WAIT_CONFIRM:
        if ((now - fallStateStartTime) > FALL_CONFIRM_TIME) {
          if (abs(totalAccel - 1.0) < 0.3) {
            fallState = FALL_CONFIRMED;
            Serial.println("\n╔════════════════════════════════════╗");
            Serial.println("║  ⚠️⚠️  XÁC NHẬN TÉ NGÃ  ⚠️⚠️        ║");
            Serial.println("╚════════════════════════════════════╝");
            
            currentPattern = BUZZER_FALL;
            sendFallSMS();
            sendAlertPacketToS3(PACKET_FALL_ALERT, "Fall Detected!");
            
            bool sosFlag = true;
            xQueueSend(sosQueue, &sosFlag, 0);
          } else {
            Serial.println("[FALL FSM] → IDLE (Đã đứng dậy)");
            fallState = FALL_IDLE;
          }
        }
        else if (abs(totalAccel - 1.0) > 0.5) {
          Serial.println("[FALL FSM] → IDLE (Chuyển động)");
          fallState = FALL_IDLE;
        }
        break;
      
      case FALL_CONFIRMED:
        if (abs(totalAccel - 1.0) > 0.5) {
          Serial.println("[FALL FSM] → IDLE (Hồi phục)");
          fallState = FALL_IDLE;
          currentPattern = BUZZER_OFF;
          fallAlertSent = false;
          accelFilter.reset();
        }
        break;
    }
  }
}

